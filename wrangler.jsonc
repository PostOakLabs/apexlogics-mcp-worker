{
  "name": "apexlogics-mcp",
  "main": "worker.mjs",
  "workers_dev": true,
  "compatibility_date": "2026-05-01",
  "compatibility_flags": ["nodejs_compat"],
  // Workers Logs — console output + invocation logs. Explicit form to match ocs-mcp /
  // ainumbers-mcp (functionally identical to the prior "enabled": true shorthand).
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  },
  "analytics_engine_datasets": [
    { "binding": "AE", "dataset": "mcp_tool_calls" }
  ],
  // Custom domain — already provisioned via dashboard; declared here for version control.
  // On first deploy after adding this, Cloudflare will confirm the existing mapping.
  "routes": [
    {
      "pattern": "mcp.apexlogics.org",
      "custom_domain": true
    }
  ]
}
